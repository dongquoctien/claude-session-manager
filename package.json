{
  "name": "claude-session-manager",
  "version": "0.2.0",
  "private": true,
  "description": "List and instantly reopen any Claude Code conversation across all your folders.",
  "license": "MIT",
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/ui",
    "packages/agent",
    "packages/desktop"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "csm": "node packages/cli/bin/csm.js",
    "web": "node packages/agent/bin/csm-web.js",
    "desktop": "npm start -w @csm/desktop",
    "desktop:dist": "npm run dist -w @csm/desktop"
  },
  "engines": {
    "node": ">=18"
  }
}
