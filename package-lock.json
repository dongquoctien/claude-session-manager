{
  "name": "claude-session-manager",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "claude-session-manager",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "packages/core",
        "packages/cli"
      ],
      "engines": {
        "node": ">=18"
      }
    },
    "node_modules/@csm/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@csm/core": {
      "resolved": "packages/core",
      "link": true
    },
    "packages/cli": {
      "name": "@csm/cli",
      "version": "0.1.0",
      "dependencies": {
        "@csm/core": "0.1.0"
      },
      "bin": {
        "csm": "bin/csm.js"
      }
    },
    "packages/core": {
      "name": "@csm/core",
      "version": "0.1.0"
    }
  }
}
